modules = ["nodejs-20", "postgresql-16"]
[deployment]
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]
deploymentTarget = "autoscale"
healthcheckPath = "/health"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 80

[agent]
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"
